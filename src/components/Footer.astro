---
import { Phone, MapPin, ArrowUpRight, Navigation, ArrowRight, ArrowUp } from '@lucide/astro';
import FacebookIcon from './FacebookIcon.astro';
import { site, mapsLink } from '../data/site';
import { servicesAZ } from '../data/services';
import { modelsByEra } from '../data/models';
import { press } from '../data/press';

const explore = [
  { label: 'About Us', href: '/about-us' },
  { label: 'Reviews', href: '/reviews' },
  { label: 'In the Press', href: '/promotions' },
  { label: 'Fun Stuff', href: '/fun-stuff' },
  { label: 'Links', href: '/links' },
  { label: 'Contact Us', href: '/contact-us' },
];
---
<footer class="relative overflow-hidden bg-ink-950 text-white/70">
  <!-- top accent + ambient glows -->
  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-500/70 to-transparent"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -right-40 -top-40 h-[28rem] w-[28rem] rounded-full bg-brand-500/12 blur-3xl"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -left-40 bottom-0 h-[24rem] w-[24rem] rounded-full bg-gold-500/[0.06] blur-3xl"></div>
  <!-- brand watermark detail -->
  <img src="/logo.png" alt="" aria-hidden="true" width="855" height="160" class="pointer-events-none absolute -bottom-6 right-4 hidden w-[34rem] max-w-[60%] select-none opacity-[0.04] [filter:brightness(0)_invert(1)] lg:block" />

  <div class="container-jg relative py-16 md:py-20">
    <!-- ── Contact panel ─────────────────────────────────────── -->
    <div class="grid items-center gap-8 rounded-4xl border border-white/10 bg-white/[0.03] p-8 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] md:p-10 lg:grid-cols-[1.35fr_1fr]">
      <div>
        <span class="eyebrow eyebrow-on-dark">Ladbroke Grove · W10</span>
        <h2 class="mt-3 text-d3 text-white">Let's talk about <span class="script-accent text-gold-400">your Volkswagen</span></h2>
        <p class="mt-3 max-w-md text-[0.95rem] leading-relaxed text-white/60">Classic or electric, a quick service or a full EV conversion - the team is here Monday to Friday, ready to help.</p>
      </div>
      <div class="flex flex-col gap-4 lg:items-end">
        <span data-open-status class="status-pill self-start border border-white/10 bg-white/5 text-white/80 lg:self-end">
          <span data-status-dot class="status-dot status-dot--open"></span>
          <span data-status-text>Mon-Fri 8am-6pm</span>
        </span>
        <a href={site.phone.href} class="group inline-flex items-center gap-3 font-mono text-2xl font-semibold tracking-tight text-white transition-colors hover:text-brand-300">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-500/15 text-brand-300 transition-colors group-hover:bg-brand-500 group-hover:text-white"><Phone size={18} /></span>
          {site.phone.display}
        </a>
        <div class="flex flex-wrap gap-2.5">
          <a href={site.phone.href} class="btn btn-primary px-5 py-2.5 text-sm">Call now</a>
          <a href={mapsLink} target="_blank" rel="noopener" class="btn btn-ghost-light px-5 py-2.5 text-sm"><Navigation size={15} /> Directions</a>
        </div>
      </div>
    </div>

    <!-- ── Link grid ─────────────────────────────────────────── -->
    <div class="mt-14 grid gap-12 lg:grid-cols-[1.25fr_1.55fr_1.1fr_1.05fr]">
      <!-- Brand -->
      <div>
        <img src="/logo.png" alt="Jack's Garage - The VW specialists" width="855" height="160" class="h-9 w-auto [filter:brightness(0)_invert(1)]" />
        <p class="mt-5 max-w-xs text-[0.95rem] leading-relaxed text-white/60">
          London's <span class="script-accent text-gold-300">Classic VW specialists</span> since 1995 - mechanical &amp; bodywork repairs, servicing and pioneering EV conversions for every Volkswagen.
        </p>
        <div class="mt-5 inline-flex items-center gap-2 rounded-pill border border-white/10 bg-white/[0.04] px-3.5 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          <span class="font-mono text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-white/70">Est. 1995 · Family run</span>
        </div>
        <div class="mt-5">
          <a href={site.facebook} target="_blank" rel="noopener" aria-label="Jack's Garage on Facebook" class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-white/70 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-300">
            <FacebookIcon size={17} />
          </a>
        </div>
      </div>

      <!-- Repairs & Services (all 26) -->
      <nav aria-label="Repairs & Services">
        <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/40"><span class="h-1 w-4 rounded-full bg-brand-500/70"></span>VW Repairs &amp; Services</h3>
        <ul class="mt-5 grid grid-cols-1 gap-x-6 gap-y-2 text-[0.9rem] sm:grid-cols-2">
          {servicesAZ.map((s) => (
            <li>
              <a href={`/services/${s.slug}`} class="group flex items-center gap-2 text-white/60 transition-colors hover:text-white">
                <span class="h-1 w-1 shrink-0 rounded-full bg-brand-500/40 transition-all duration-300 group-hover:w-2 group-hover:bg-brand-500"></span>
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- VW Servicing + Explore -->
      <div>
        <nav aria-label="VW Servicing">
          <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/40"><span class="h-1 w-4 rounded-full bg-brand-500/70"></span>VW Servicing</h3>
          {modelsByEra.map((g) => (
            <div class="mt-4">
              <p class="text-[0.7rem] font-semibold uppercase tracking-[0.1em] text-gold-500/80">{g.label}</p>
              <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-[0.85rem]">
                {g.items.map((m) => (
                  <li><a href={`/car-service-prices/vw/${m.slug}`} class="text-white/55 transition-colors hover:text-white">{m.short}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
        <nav aria-label="Explore" class="mt-7">
          <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/40"><span class="h-1 w-4 rounded-full bg-brand-500/70"></span>Explore</h3>
          <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-[0.9rem]">
            {explore.map((n) => (
              <li><a href={n.href} class="link-underline text-white/60 transition-colors hover:text-white">{n.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Visit & contact card -->
      <div>
        <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/40"><span class="h-1 w-4 rounded-full bg-brand-500/70"></span>Visit us</h3>
        <div class="mt-5 rounded-3xl border border-white/10 bg-white/[0.03] p-5">
          <a href={mapsLink} target="_blank" rel="noopener" class="group flex gap-3">
            <MapPin size={18} class="mt-0.5 shrink-0 text-brand-400" />
            <span class="text-[0.95rem] leading-relaxed text-white/70 transition-colors group-hover:text-white">{site.address.line1}<br />{site.address.city} <span class="font-mono">{site.address.postcode}</span></span>
          </a>
          <div class="my-4 h-px w-full bg-white/10"></div>
          <a href={site.phone.href} class="flex items-center gap-3 text-white transition-colors hover:text-brand-300">
            <Phone size={18} class="shrink-0 text-brand-400" /><span class="font-mono text-[1.05rem]">{site.phone.display}</span>
          </a>
          <p class="mt-3 flex gap-3 text-[0.9rem] text-white/60">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" class="mt-0.5 shrink-0 text-brand-400"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            <span>Mon-Fri 8:00-18:00<br />Sat &amp; Sun Closed</span>
          </p>
          <a href={mapsLink} target="_blank" rel="noopener" class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-pill border border-white/15 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:border-brand-400 hover:text-brand-300">
            <Navigation size={15} /> Get directions <ArrowUpRight size={14} />
          </a>
        </div>
      </div>
    </div>

    <!-- ── As featured in ────────────────────────────────────── -->
    <div class="mt-14 border-t border-white/10 pt-8">
      <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center sm:gap-8">
        <span class="shrink-0 font-mono text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/35">As featured in</span>
        <ul class="flex flex-wrap items-center justify-center gap-x-7 gap-y-2">
          {press.map((p) => (
            <li><a href={`/promotions/${p.slug}`} class="text-[0.8rem] font-semibold uppercase tracking-wide text-white/45 transition-colors hover:text-gold-300">{p.magazine.replace(' Magazine', '')}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ── Bottom bar ────────────────────────────────────────── -->
    <div class="mt-10 flex flex-col items-center justify-between gap-5 border-t border-white/10 pt-7 text-sm text-white/45 md:flex-row">
      <p>© {site.copyrightYear} {site.name}. All rights reserved.</p>
      <nav aria-label="Legal" class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <a href="/privacy-policy" class="transition-colors hover:text-white">Privacy Policy</a>
        <a href="/cookie-policy" class="transition-colors hover:text-white">Cookie Policy</a>
        <button type="button" data-to-top class="inline-flex items-center gap-1.5 rounded-pill border border-white/15 px-3.5 py-1.5 text-white/70 transition-colors hover:border-brand-400 hover:text-brand-300">
          Back to top <ArrowUp size={14} />
        </button>
      </nav>
    </div>
  </div>

  <script>
    document.querySelectorAll('[data-to-top]').forEach((b) =>
      b.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))
    );
  </script>
</footer>
