---
import { ArrowUpRight } from '@lucide/astro';
import Icon from './Icon.astro';
import type { Service } from '../data/services';
interface Props { service: Service; index?: number }
const { service, index = 0 } = Astro.props;
---
<a
  href={`/services/${service.slug}`}
  class="service-card reveal group"
  style={`--reveal-delay:${(index % 3) * 90}ms`}
  aria-label={`${service.name} - ${service.tagline}`}
>
  <div class="relative aspect-[16/10] overflow-hidden">
    <img
      src={service.image}
      alt={service.name}
      width="825" height="410" loading="lazy" decoding="async"
      class="service-card__img h-full w-full object-cover transition-transform duration-700 ease-out"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/65 via-ink/10 to-transparent"></div>
    <span class="absolute left-4 top-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-white/90 text-brand-600 shadow-glass backdrop-blur">
      <Icon name={service.icon} size={22} />
    </span>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-h3 font-bold text-ink">{service.name}</h3>
    <p class="mt-2 flex-1 text-[0.95rem] leading-relaxed text-muted">{service.tagline}</p>
    <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-ink">
      Learn more
      <span class="service-card__arrow inline-flex h-7 w-7 items-center justify-center rounded-full bg-brand-50 text-brand-600 transition-all duration-300">
        <ArrowUpRight size={16} strokeWidth={2.2} />
      </span>
    </span>
  </div>
</a>
