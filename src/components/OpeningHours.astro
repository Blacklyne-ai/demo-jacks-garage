---
import { site } from '../data/site';
interface Props { class?: string }
const { class: cls = '' } = Astro.props;
// Render Monday-first.
const ordered = [...site.hours].sort((a, b) => ((a.dow + 6) % 7) - ((b.dow + 6) % 7));
---
<div class:list={['rounded-3xl border border-line bg-white p-6 shadow-card md:p-7', cls]}>
  <div class="flex items-center justify-between gap-3">
    <h3 class="text-h3 font-bold text-ink">Opening hours</h3>
    <span data-open-status class="status-pill border border-line bg-surface text-ink-700">
      <span data-status-dot class="status-dot status-dot--open"></span>
      <span data-status-text>Mon-Fri 8am-6pm</span>
    </span>
  </div>
  <ul class="mt-5 divide-y divide-line">
    {ordered.map((h) => (
      <li data-dow={h.dow} class="flex items-center justify-between py-2.5 text-[0.95rem]">
        <span class="font-medium text-ink-700">{h.day}</span>
        {h.closed
          ? <span class="font-mono text-muted">Closed</span>
          : <span class="font-mono text-ink">{h.open} - {h.close}</span>}
      </li>
    ))}
  </ul>
</div>

<script>
  // Highlight today's row.
  const dow = new Date().getDay();
  document.querySelectorAll<HTMLElement>('[data-dow]').forEach((li) => {
    if (Number(li.dataset.dow) === dow) {
      li.classList.add('rounded-xl', 'bg-brand-50', 'px-3', '-mx-3');
    }
  });
</script>
