---
// UK GDPR / PECR consent banner. The site itself sets no marketing cookies;
// only the embedded Google Map may set cookies, hence the choice.
import { Cookie } from '@lucide/astro';
---
<div id="cookieBanner" class="fixed inset-x-0 bottom-0 z-[150] hidden px-3 pb-3 lg:bottom-4 lg:left-4 lg:right-auto lg:max-w-md lg:px-0 lg:pb-0">
  <div class="glass rounded-3xl p-5 shadow-glass-lg">
    <div class="flex items-start gap-3">
      <span class="icon-tile h-11 w-11 shrink-0"><Cookie size={20} /></span>
      <div>
        <p class="text-sm font-semibold text-ink">We value your privacy</p>
        <p class="mt-1 text-[0.85rem] leading-relaxed text-muted">
          We use essential cookies to make this site work and optional cookies (such as the embedded map) to improve your experience. See our <a href="/cookie-policy" class="font-medium text-brand-700 underline underline-offset-2">Cookie Policy</a>.
        </p>
      </div>
    </div>
    <div class="mt-4 flex gap-2">
      <button id="cookieAccept" type="button" class="btn btn-primary flex-1 py-2.5 text-sm">Accept all</button>
      <button id="cookieReject" type="button" class="btn btn-outline flex-1 py-2.5 text-sm">Necessary only</button>
    </div>
  </div>
</div>

<script>
  const KEY = 'jg-cookie-consent';
  const banner = document.getElementById('cookieBanner');
  const show = () => banner?.classList.remove('hidden');
  const hide = () => banner?.classList.add('hidden');
  try {
    if (!localStorage.getItem(KEY)) setTimeout(show, 700);
  } catch { setTimeout(show, 700); }
  const set = (v: string) => { try { localStorage.setItem(KEY, v); } catch {} hide(); };
  document.getElementById('cookieAccept')?.addEventListener('click', () => set('all'));
  document.getElementById('cookieReject')?.addEventListener('click', () => set('necessary'));
</script>
