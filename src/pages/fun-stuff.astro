---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { Phone, Play, ArrowRight, ArrowUpRight, Camera } from '@lucide/astro';
import { site } from '../data/site';

// The other films that live on the original Jack's Garage channel.
// Listed as flavour cards, NOT links (we only embed the main review film below).
const moreFilms = [
  { title: 'A 1957 Porsche', caption: 'A guest appearance in the workshop.' },
  { title: 'Another day at Jack\'s Garage', caption: 'Life behind the doors in W10.' },
  { title: 'Caroline in Daisy!', caption: 'One of our favourite Beetles out on the road.' },
  { title: 'A behind the scenes of Classic Car Club London', caption: 'Jack\'s Garage service and paint all their VWs!' },
  { title: 'Berty, the Gin Genie VW van', caption: 'With Mum and Dad ready to take him home!' },
];

// Our own personal collection - straight from life at the garage.
const gallery = [
  'ws-01', 'ws-19', 'ws-02', 'ev-02', 'ws-03', 'ws-04', 'ws-17', 'ws-05',
  'ev-03', 'ws-08', 'ws-10', 'ws-30', 'ws-11', 'ev-04', 'ws-14', 'ws-20',
  'ws-21', 'ws-33', 'ws-24', 'ws-27', 'ev-07', 'ws-28', 'ws-35', 'ws-47',
  'ws-48', 'ws-49',
].map((id) => ({
  src: id.startsWith('ev') ? `/images/ev/${id}.jpg` : `/images/workshop/${id}.jpg`,
  alt: 'Life at Jack\'s Garage',
}));
---
<Layout
  title="Fun Stuff - Jack's Garage | Classic VW Specialists London W10"
  description="Pictures and video of life at Jack's Garage, the Classic VW specialists in Ladbroke Grove, London W10. A peek behind the workshop doors. We love VWs."
  path="/fun-stuff"
  image="/images/workshop/ws-19.jpg"
>
  <PageHero
    eyebrow="Fun Stuff"
    title="Pictures & video of life at Jack's Garage"
    subtitle="We love VWs - here's a peek behind the <strong>workshop doors</strong>."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Fun Stuff' }]}
  >
    <a href="#gallery" class="btn btn-primary btn-lg">See the gallery <Camera size={18} /></a>
    <a href={site.facebook} target="_blank" rel="noopener" class="btn btn-outline btn-lg">Follow on Facebook <ArrowUpRight size={16} class="arrow" /></a>
  </PageHero>

  <!-- VIDEO -->
  <section class="section bg-ink-950">
    <div class="container-jg">
      <SectionHeading
        dark
        align="left"
        eyebrow="On film"
        title="A day in the life of the workshop"
        intro="Press play and come behind the scenes with the team."
        class="max-w-2xl"
      />

      <figure class="reveal mt-12">
        <div class="relative aspect-video overflow-hidden rounded-3xl border border-white/10 bg-ink-900 shadow-glass-lg">
          <iframe
            src="https://www.youtube.com/embed/IqyW021Z9Nw?rel=0"
            title="Jack's Garage Car Mechanic in London: Auto Body Repair and VW Service"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
            class="absolute inset-0 h-full w-full"
          ></iframe>
        </div>
        <figcaption class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-white/70">
          <span class="chip border-white/15 bg-white/10 text-white">#BigReviewTV</span>
          <span>Our #BigReviewTV review - auto body repair and VW service, filmed here in Ladbroke Grove.</span>
        </figcaption>
      </figure>

      <!-- More films (flavour cards, not links) -->
      <div class="mt-14">
        <p class="reveal text-sm font-semibold uppercase tracking-wide text-gold-300">More from the channel</p>
        <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {moreFilms.map((f, i) => (
            <li class="reveal group flex items-start gap-4 rounded-2xl border border-white/10 bg-white/[0.04] p-5 transition-colors duration-300 hover:border-white/20 hover:bg-white/[0.07]" style={`--reveal-delay:${(i % 3) * 80}ms`}>
              <span class="mt-0.5 inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-500/15 text-brand-400 transition-colors duration-300 group-hover:bg-brand-500 group-hover:text-white">
                <Play size={18} />
              </span>
              <span class="min-w-0">
                <span class="block text-[0.98rem] font-semibold leading-snug text-white">{f.title}</span>
                <span class="mt-1 block text-sm leading-relaxed text-white/60">{f.caption}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery" class="section scroll-mt-28">
    <div class="container-jg">
      <SectionHeading
        eyebrow="The gallery"
        title="Our own personal collection of photos from life at the garage"
        intro="Classics in for a service, paintwork in progress, EV conversions on the bench, and a workshop full of Volkswagens we love."
      />

      <div class="mt-14 columns-2 gap-4 md:columns-3 lg:columns-4 [column-fill:_balance]">
        {gallery.map((img, i) => (
          <figure class="reveal group mb-4 break-inside-avoid overflow-hidden rounded-2xl border border-line bg-cream-200 shadow-card" style={`--reveal-delay:${(i % 4) * 70}ms`}>
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              decoding="async"
              class="w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
            />
          </figure>
        ))}
      </div>

      <p class="reveal mx-auto mt-10 max-w-2xl text-center text-sm text-muted">
        Spot your VW in here? Tag us when you share - we love seeing them out on the road.
      </p>
    </div>
  </section>

  <!-- Small CTA to /links -->
  <section class="section bg-cream-200 pt-0">
    <div class="container-jg">
      <div class="reveal flex flex-col items-center justify-between gap-6 rounded-3xl border border-line bg-white p-7 shadow-card sm:flex-row sm:p-9">
        <div class="flex items-start gap-4">
          <span class="icon-tile shrink-0"><Icon name="Sparkles" size={24} /></span>
          <div>
            <h3 class="text-h3 font-bold text-ink">More <span class="script-accent text-brand-600">VW goodness</span></h3>
            <p class="mt-1 text-[0.95rem] leading-relaxed text-muted">Our favourite parts suppliers, clubs and shows - all the links we love in one place.</p>
          </div>
        </div>
        <a href="/links" class="btn btn-primary btn-lg shrink-0">More VW goodness <ArrowRight size={18} class="arrow" /></a>
      </div>
    </div>
  </section>

  <CtaBand
    title="Fancy bringing your VW down?"
    subtitle="Whether it is a service, paintwork or an EV conversion, the team would love to help. Call us or pop in to Ladbroke Grove."
  />
</Layout>
