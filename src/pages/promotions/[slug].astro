---
import Layout from '../../layouts/Layout.astro';
import CtaBand from '../../components/CtaBand.astro';
import DetailSidebar from '../../components/DetailSidebar.astro';
import { ArrowRight, ArrowLeft, Quote, Newspaper, Images } from '@lucide/astro';
import Icon from '../../components/Icon.astro';
import { press, getPress } from '../../data/press';
import { site } from '../../data/site';

export function getStaticPaths() {
  return press.map((p) => ({ params: { slug: p.slug }, props: { feature: p } }));
}

const { feature } = Astro.props;
const others = press.filter((p) => p.slug !== feature.slug);
---
<Layout
  title={`Jack's Garage in ${feature.magazine}, ${feature.edition} - Classic VW EV Conversions`}
  description={`${feature.magazine}, ${feature.edition}: ${feature.excerpt}`.slice(0, 154)}
  path={`/promotions/${feature.slug}`}
  image={feature.cover}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-white pt-32 md:pt-40">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-grid-faint opacity-60 [background-size:46px_46px]"></div>
    <div aria-hidden="true" class="pointer-events-none absolute -right-24 -top-24 h-[30rem] w-[30rem] rounded-full bg-brand-500/10 blur-3xl"></div>
    <div class="container-jg relative grid items-center gap-12 pb-14 md:pb-20 lg:grid-cols-2">
      <div>
        <nav aria-label="Breadcrumb" class="reveal mb-6 flex flex-wrap items-center gap-2 text-sm text-muted">
          <a href="/" class="transition-colors hover:text-brand-700">Home</a><span class="text-line">/</span>
          <a href="/promotions" class="transition-colors hover:text-brand-700">In the Press</a><span class="text-line">/</span>
          <span class="text-ink">{feature.magazine}</span>
        </nav>
        <span class="eyebrow reveal">{feature.topic}</span>
        <h1 class="reveal mt-4 text-d3 text-ink" style="--reveal-delay:60ms">{feature.magazine}</h1>
        <p class="reveal mt-2 font-mono text-sm font-semibold uppercase tracking-wide text-brand-700" style="--reveal-delay:90ms">{feature.edition}</p>
        <figure class="reveal mt-6 rounded-3xl border border-line bg-cream-200 p-7" style="--reveal-delay:120ms">
          <Quote size={28} class="text-brand-300" />
          <blockquote class="mt-3 font-serif text-xl italic leading-snug text-ink md:text-2xl">{feature.excerpt}</blockquote>
        </figure>
        <div class="reveal mt-7 flex flex-wrap gap-3" style="--reveal-delay:160ms">
          <a href="/services/electric-vehicle-conversions" class="btn btn-primary btn-lg">About our EV Conversions <ArrowRight size={16} class="arrow" /></a>
          <a href="/promotions" class="btn btn-outline btn-lg"><ArrowLeft size={16} /> All features</a>
        </div>
      </div>
      <div class="reveal relative" style="--reveal-delay:140ms">
        <div aria-hidden="true" class="absolute -inset-3 -z-10 rounded-[2.25rem] bg-orange-grad opacity-15 blur-2xl"></div>
        <img src={feature.cover} alt={`${feature.magazine}, ${feature.edition}`} width="600" height="400" loading="eager" class="aspect-[3/2] w-full rounded-3xl border border-line object-cover shadow-glass-lg" />
      </div>
    </div>
  </section>

  <!-- Body -->
  <section class="section">
    <div class="container-jg grid gap-12 lg:grid-cols-[1.7fr_1fr]">
      <div>
        <div class="prose-jg max-w-2xl">
          <p class="text-body-xl text-ink-700">In {feature.edition}, {feature.magazine} featured Jack's Garage and our work converting classic Volkswagens to electric.</p>
          <p>{feature.excerpt}</p>
          <p>It's part of a remarkable run of editorial interest in early 2020, when six motoring titles told the story of a London family workshop reinventing the Volkswagens it loves - as the UK distributor of eClassics' conversion kits, using genuine VW components.</p>
        </div>

        <div class="mt-8 inline-flex items-center gap-3 rounded-2xl border border-line bg-cream-200 px-5 py-4">
          <span class="icon-tile h-11 w-11"><Images size={20} /></span>
          <span><span class="block font-semibold text-ink">{feature.pages}-page feature</span><span class="block text-sm text-muted">as it appeared in {feature.magazine}</span></span>
        </div>

        <!-- Other features -->
        <div class="mt-12">
          <h2 class="text-h3 font-bold text-ink">More press features</h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            {others.map((o) => (
              <a href={`/promotions/${o.slug}`} class="group flex items-center gap-4 rounded-2xl border border-line bg-white p-4 shadow-card transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-card-hover">
                <img src={o.cover} alt={o.magazine} width="96" height="64" loading="lazy" class="h-14 w-20 shrink-0 rounded-lg object-cover" />
                <span class="min-w-0 flex-1">
                  <span class="block truncate text-[0.9rem] font-semibold text-ink">{o.magazine.replace(' Magazine', '')}</span>
                  <span class="block text-xs text-muted">{o.edition}</span>
                </span>
                <ArrowRight size={15} class="shrink-0 text-muted transition-transform group-hover:translate-x-0.5 group-hover:text-brand-600" />
              </a>
            ))}
          </div>
        </div>
      </div>

      <DetailSidebar />
    </div>
  </section>

  <CtaBand />
</Layout>
